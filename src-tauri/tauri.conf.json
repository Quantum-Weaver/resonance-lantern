{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Resonance Lantern",
  "version": "0.1.1",
  "identifier": "com.audhd.resonance-lantern",
  "build": {
    "beforeDevCommand": "node scripts/sync-android-extras.mjs && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/sync-android-extras.mjs && npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Resonance Lantern",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
